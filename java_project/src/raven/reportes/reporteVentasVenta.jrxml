	<variable name="promedioVenta" calculation="Count" class="java.math.BigDecimal">
		<expression><![CDATA[$F{ventas_totales}.divide(new java.math.BigDecimal($F{cantidad_ventas}), 2, java.math.RoundingMode.HALF_UP)]]></expression>
		<initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
	</variable>
