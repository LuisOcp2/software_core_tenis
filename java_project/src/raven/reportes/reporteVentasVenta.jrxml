<jasperReport name="reporteVentas" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="13acf49e-4913-4d1b-bccc-113817ad15d1">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CONEXION REMOTE XTREME"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="350"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="639"/>
	<style name="Title" forecolor="#FFFFFF" fontName="Times New Roman" fontSize="50.0" bold="false"/>
	<style name="SubTitle" forecolor="#CCCCCC" fontName="Times New Roman" fontSize="18.0" bold="false"/>
	<style name="Column header" forecolor="#666666" fontName="Times New Roman" fontSize="14.0" bold="true"/>
	<style name="Detail" mode="Transparent" fontName="Times New Roman"/>
	<style name="Row" mode="Transparent" fontName="Times New Roman" pdfFontName="Times-Roman">
		<conditionalStyle mode="Opaque" backcolor="#F0EFEF">
			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
		</conditionalStyle>
	</style>
	<parameter name="fechaInicio" class="java.util.Date"/>
	<parameter name="fechaFin" class="java.util.Date"/>
	<parameter name="idCliente" class="java.lang.Integer"/>
	<parameter name="estado" class="java.lang.String"/>
	<parameter name="titulo" class="java.lang.String"/>
	<parameter name="filtrosDescripcion" class="java.lang.String"/>
	<parameter name="bodega" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    v.id_venta,
    v.id_cliente,
    c.nombre AS nombre_cliente,
    v.id_usuario,
    u.nombre AS nombre_usuario,
    b.nombre AS nombre_bodega,  -- NUEVO: Nombre de la bodega
    v.fecha_venta,
    v.subtotal,
    v.descuento,
    v.iva,
    v.total,
    v.estado,
    v.tipo_pago,
    v.observaciones,

    /* Estadísticas generales */
    (SELECT COALESCE(SUM(v2.total), 0)
     FROM soft_xtreme.ventas v2
     JOIN soft_xtreme.usuarios u2 ON v2.id_usuario = u2.id_usuario
     WHERE ($P{fechaInicio} IS NULL OR v2.fecha_venta >= $P{fechaInicio})
       AND ($P{fechaFin} IS NULL OR v2.fecha_venta <= $P{fechaFin})
       AND ($P{idCliente} IS NULL OR v2.id_cliente = $P{idCliente})
       AND ($P{estado} IS NULL OR v2.estado = $P{estado})
       AND ($P{bodega} IS NULL OR u2.id_bodega = $P{bodega})
       AND v2.estado IN ('completada', 'pendiente')) AS ventas_totales,

    (SELECT COUNT(*)
     FROM soft_xtreme.ventas v2
     JOIN soft_xtreme.usuarios u2 ON v2.id_usuario = u2.id_usuario
     WHERE ($P{fechaInicio} IS NULL OR v2.fecha_venta >= $P{fechaInicio})
       AND ($P{fechaFin} IS NULL OR v2.fecha_venta <= $P{fechaFin})
       AND ($P{idCliente} IS NULL OR v2.id_cliente = $P{idCliente})
       AND ($P{estado} IS NULL OR v2.estado = $P{estado})
       AND ($P{bodega} IS NULL OR u2.id_bodega = $P{bodega})
       AND v2.estado IN ('completada', 'pendiente')) AS cantidad_ventas,

    /* Subconsulta para productos vendidos usando venta_detalles */
    (SELECT COALESCE(SUM(vd.cantidad), 0)
     FROM soft_xtreme.venta_detalles vd
     JOIN soft_xtreme.ventas v2 ON vd.id_venta = v2.id_venta
     JOIN soft_xtreme.usuarios u2 ON v2.id_usuario = u2.id_usuario
     WHERE ($P{fechaInicio} IS NULL OR v2.fecha_venta >= $P{fechaInicio})
       AND ($P{fechaFin} IS NULL OR v2.fecha_venta <= $P{fechaFin})
       AND ($P{idCliente} IS NULL OR v2.id_cliente = $P{idCliente})
       AND ($P{estado} IS NULL OR v2.estado = $P{estado})
       AND ($P{bodega} IS NULL OR u2.id_bodega = $P{bodega})
       AND v2.estado IN ('completada', 'pendiente')) AS productos_vendidos

FROM
    soft_xtreme.ventas v
LEFT JOIN
    soft_xtreme.clientes c ON v.id_cliente = c.id_cliente
LEFT JOIN
    soft_xtreme.usuarios u ON v.id_usuario = u.id_usuario
LEFT JOIN
    soft_xtreme.bodegas b ON u.id_bodega = b.id_bodega  -- NUEVO: JOIN con tabla bodegas
WHERE
    ($P{fechaInicio} IS NULL OR v.fecha_venta >= $P{fechaInicio})
AND
    ($P{fechaFin} IS NULL OR v.fecha_venta <= $P{fechaFin})
AND
    ($P{idCliente} IS NULL OR v.id_cliente = $P{idCliente})
AND
    ($P{estado} IS NULL OR v.estado = $P{estado})
AND
    ($P{bodega} IS NULL OR u.id_bodega = $P{bodega})
ORDER BY
    v.fecha_venta DESC]]></query>
