	<parameter name="idventaV" class="java.lang.String">
		<defaultValueExpression><![CDATA[$F{id_venta}]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
    ventas.id_venta,
    ventas.fecha_venta,
    ventas.subtotal,
    ventas.descuento,
    ventas.iva,
    ventas.total,
    ventas.tipo_pago,
    ventas.estado AS ventas_estado,
    ventas.observaciones AS ventas_observaciones,

    clientes.id_cliente,
    clientes.nombre AS clientes_nombre,
    clientes.dni,
    clientes.direccion AS clientes_direccion,
    clientes.telefono AS clientes_telefono,
    clientes.email AS clientes_email,

    usuarios.id_usuario,
    usuarios.nombre AS usuarios_nombre,
    usuarios.username,
    usuarios.email AS usuarios_email,
    usuarios.rol,

    productos.id_producto,
    productos.nombre AS productos_nombre,
    productos.codigo_modelo,
    COALESCE(pv.ean, productos.codigo_modelo) AS codigo_barras,
    productos.precio_venta,
    CASE 
    WHEN venta_detalles.tipo_venta = 'salida par' THEN COALESCE(t.numero, productos.talla)
   ELSE NULL 
    END AS talla,
    COALESCE(c.nombre, productos.color) AS color,
    productos.genero,

    venta_detalles.id_detalle,
    venta_detalles.cantidad,
    venta_detalles.precio_unitario,
    venta_detalles.descuento AS venta_detalles_descuento,
    venta_detalles.subtotal AS venta_detalles_subtotal,
    venta_detalles.tipo_venta, 

    inventario_movimientos.id_movimiento,
    inventario_movimientos.tipo_movimiento,
    inventario_movimientos.cantidad AS inventario_movimientos_cantidad,
    inventario_movimientos.cantidad_pares,
    inventario_movimientos.fecha_movimiento,
    inventario_movimientos.observaciones AS inventario_movimientos_observaciones,

    (venta_detalles.cantidad * venta_detalles.precio_unitario) AS total_sin_descuento,
    (venta_detalles.descuento * venta_detalles.cantidad) AS descuento_total,
    (venta_detalles.subtotal / venta_detalles.cantidad) AS precio_unitario_final

FROM
    ventas
LEFT JOIN
    clientes ON ventas.id_cliente = clientes.id_cliente
INNER JOIN
    usuarios ON ventas.id_usuario = usuarios.id_usuario
INNER JOIN
    venta_detalles ON ventas.id_venta = venta_detalles.id_venta
INNER JOIN
    productos ON venta_detalles.id_producto = productos.id_producto
LEFT JOIN
    producto_variantes pv ON productos.id_producto = pv.id_producto AND venta_detalles.id_variante = pv.id_variante
LEFT JOIN
    tallas t ON pv.id_talla = t.id_talla
LEFT JOIN
    colores c ON pv.id_color = c.id_color
LEFT JOIN
    inventario_movimientos ON (
        inventario_movimientos.id_producto = productos.id_producto
        AND inventario_movimientos.tipo_referencia = 'venta_detalle'
        AND inventario_movimientos.id_referencia = venta_detalles.id_detalle
    )
WHERE
    ventas.id_venta =  $P{idventaV} 
    AND venta_detalles.activo = 1 
ORDER BY
    ventas.fecha_venta DESC, ventas.id_venta, productos.nombre]]></query>
